# SaferStreets Environment Configuration

# Database
DATABASE_URL=postgresql://saferstreets:password@localhost:5432/saferstreets
POSTGRES_USER=saferstreets
POSTGRES_PASSWORD=password
POSTGRES_DB=saferstreets

# Redis
REDIS_URL=redis://localhost:6379

# API
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Weather API (optional)
WEATHER_API_KEY=your_openweathermap_key_here

# Mapbox/Map tiles (optional)
MAPBOX_TOKEN=your_mapbox_token_here

# AWS S3 (for media uploads in phase 2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=saferstreets-tiles
AWS_REGION=us-east-1

# Analytics (privacy-preserving)
SENTRY_DSN=
ANALYTICS_ENABLED=false

# Mobile app callback URL
MOBILE_APP_SCHEME=saferstreets://
